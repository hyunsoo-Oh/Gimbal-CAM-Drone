#ifndef SRC_IMU_ICM_42688_P_ICM_42688_P_REG_H_
#define SRC_IMU_ICM_42688_P_ICM_42688_P_REG_H_

// =======================================================
// User Bank 0 Register Map
// =======================================================

typedef union
{
    struct
    {
        uint8_t soft_reset_config : 1;  // bit 0    : Soft Reset 설정 - 1로 설정하면 디바이스 소프트 리셋 수행
        uint8_t reserved0         : 3;  // bit 1~3  : Reserved
        uint8_t spi_mode          : 1;  // bit 4    : SPI Mode 설정
        uint8_t reserved1         : 3;  // bit 5~7  : Reserved
    } bits;
    uint8_t reg;
} Device_Config;

typedef union
{
    struct
    {
        uint8_t spi_slew_rate	  : 3;  // bit 0~2  : Soft Reset 설정 - 1로 설정하면 디바이스 소프트 리셋 수행
        uint8_t i2c_slew_rate     : 3;  // bit 4~5  : Reserved
        uint8_t reserved          : 1;  // bit 6~7  : Reserved
    } bits;
    uint8_t reg;
} Drive_Config;

typedef union
{
    struct
    {
        uint8_t int1_polarity	  : 1;  // bit 0    : Soft Reset 설정 - 1로 설정하면 디바이스 소프트 리셋 수행
        uint8_t i2c_slew_rate     : 1;  // bit 1	: Reserved
        uint8_t reserved0         : 1;  // bit 6    : Reserved
        uint8_t reserved2         : 1;  // bit 7  	: Reserved
    } bits;
    uint8_t reg;
} Int_Config;

#endif /* SRC_IMU_ICM_42688_P_ICM_42688_P_REG_H_ */
